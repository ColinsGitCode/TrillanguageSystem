FROM node:20-alpine

WORKDIR /app

COPY services/geminiGatewayServer.js /app/services/geminiGatewayServer.js
COPY services/geminiTimeouts.js /app/services/geminiTimeouts.js
COPY services/geminiErrors.js /app/services/geminiErrors.js
COPY lib/logger.js /app/lib/logger.js

EXPOSE 18888

CMD ["node", "/app/services/geminiGatewayServer.js"]

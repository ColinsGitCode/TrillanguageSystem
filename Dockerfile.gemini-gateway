FROM node:20-alpine

WORKDIR /app

COPY services/llm/geminiGatewayServer.js /app/services/llm/geminiGatewayServer.js
COPY services/llm/geminiTimeouts.js /app/services/llm/geminiTimeouts.js
COPY services/llm/geminiErrors.js /app/services/llm/geminiErrors.js
COPY lib/logger.js /app/lib/logger.js

EXPOSE 18888

CMD ["node", "/app/services/llm/geminiGatewayServer.js"]

# ========================================
# ⚠️ ARCHIVED: Google Gemini API (已封存)
# ========================================
# 封存日期：2026-02-03
# 原因：转向本地LLM方案（Qwen2.5等开源模型）
# 如需重新启用，取消下面注释并填入真实API Key
# ========================================
# GEMINI_API_KEY=your_gemini_api_key_here
# GEMINI_MODEL=gemini-2.5-flash-lite
# GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# ========================================
# Gemini CLI（本地命令行模式）
# ========================================
# GEMINI_MODE=host-proxy
# GEMINI_PROXY_URL=http://host.docker.internal:18888/api/gemini
# GEMINI_PROXY_AUTH_MODE=apikey
# GEMINI_PROXY_API_KEY=tri-lang-learning-6a96f31e3a32b32ce404d9c6a91670b9
# GEMINI_PROXY_BEARER_TOKEN=
# GEMINI_PROXY_SOURCE_APP=tri-lang-learning-system
# GEMINI_PROXY_SOURCE_ENV=prod
# GEMINI_PROXY_PROJECT=tri-lang-learning-system
# GEMINI_PROXY_MODEL=gemini-3-flash-preview
# TRAINING_TEACHER_MODEL=gemini-3-flash-preview
# --- Chain timeouts: one budget, all hops derive (services/geminiTimeouts.js) ---
# GEMINI_EXECUTION_BUDGET_MS — normal interactive CLI run budget
# GEMINI_MAX_EXECUTION_BUDGET_MS — hard ceiling for any run (sized for training)
# GEMINI_HOP_BUFFER_MS — slack added per transport hop (client > gateway > executor)
# GEMINI_EXECUTION_BUDGET_MS=234000
# GEMINI_MAX_EXECUTION_BUDGET_MS=240000
# GEMINI_HOP_BUFFER_MS=15000
# Legacy envs are still read for compatibility with older deployments.
# GEMINI_PROXY_REQUEST_TIMEOUT_MS=260000
# GEMINI_PROXY_EXECUTION_TIMEOUT_MS=234000
# --- Host executor concurrency (scripts/gemini-host-proxy.js) ---
# GEMINI_MAX_CONCURRENT — max gemini CLI processes at once (backpressure)
# GEMINI_QUEUE_WAIT_MS — how long a request waits for a slot before 429
# GEMINI_MAX_CONCURRENT=2
# GEMINI_QUEUE_WAIT_MS=30000
# GEMINI_PROXY_PARAM_POLICY=strict
# GEMINI_PROXY_ENFORCE_GATEWAY=true
# GEMINI_PROXY_PREFER_IPV4=true
# GEMINI_PROXY_IPV4_FALLBACK=192.168.65.254
# GEMINI_PROXY_RETRIES=1
# GEMINI_PROXY_AUTO_RESET=true
# GEMINI_PROXY_RETRY_DELAY_MS=1200
# TRAINING_PROXY_TIMEOUT_MS=260000
# TRAINING_PROXY_EXECUTION_TIMEOUT_MS=234000
# TRAINING_PROXY_RETRIES=1
# TRAINING_PROXY_RETRY_DELAY_MS=1200
# TRAINING_PROXY_RESET_ON_TIMEOUT=true
# TRAINING_PROXY_RETRY_ON_TIMEOUT=true
# TRAINING_REPAIR_TIMEOUT_MS=90000
# TRAINING_REPAIR_EXECUTION_TIMEOUT_MS=60000
# TRAINING_REPAIR_RETRIES=0
# TRAINING_BACKFILL_PROXY_TIMEOUT_MS=120000
# TRAINING_BACKFILL_EXECUTION_TIMEOUT_MS=100000
# TRAINING_BACKFILL_PROXY_RETRIES=0
# TRAINING_BACKFILL_RETRY_DELAY_MS=600
# TRAINING_BACKFILL_RETRY_ON_TIMEOUT=false
# TRAINING_BACKFILL_REPAIR_TIMEOUT_MS=25000
# TRAINING_BACKFILL_REPAIR_EXECUTION_TIMEOUT_MS=18000
# TRAINING_BACKFILL_REPAIR_RETRIES=0
# TRAINING_BACKFILL_DISABLE_REPAIR_ON_TIMEOUT=true
# GEMINI_FALLBACK_TO_LOCAL=true
# GEMINI_CLI_MODEL=gemini-3-pro-preview
# GEMINI_TEACHER_MODEL=gemini-3-pro-preview
# MARKDOWN_PROMPT_PATH=./prompts/phrase_3LANS_markdown.md
# GRAMMAR_MARKDOWN_PROMPT_PATH=./prompts/phrase_ja_grammar_markdown.md


# ========================================
# 本地 LLM 配置（当前主要方案）
# ========================================
LLM_BASE_URL=http://localhost:15800/v1
LLM_API_KEY=EMPTY
LLM_MODEL=qwen2_5_vl
LLM_OCR_MODEL=qwen2_5_vl

# LLM 参数配置
LLM_MAX_TOKENS=2048
LLM_OCR_MAX_TOKENS=512
LLM_TEMPERATURE=0.2
# LLM_OUTPUT_MODE=markdown

# ========================================
# DeepSeek 配置（/api/generate 当前生成路径）
# ========================================
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_TIMEOUT_MS=120000
DEEPSEEK_THINKING=disabled
# 成本估算可选覆盖项，单位为 USD / 1M tokens；留空时按 DEEPSEEK_MODEL 使用内置默认值。
# DEEPSEEK_INPUT_COST_PER_1M=
# DEEPSEEK_OUTPUT_COST_PER_1M=

# ========================================
# OCR 配置（推荐：Tesseract 独立容器）
# ========================================
# OCR_PROVIDER=tesseract   # tesseract | local | auto
# OCR_TESSERACT_ENDPOINT=http://ocr:8080/ocr
# OCR_LANGS=eng+jpn+chi_sim
# OCR_TIMEOUT_MS=20000

# ========================================
# Few-shot (Golden Examples) 配置
# ========================================
# ENABLE_GOLDEN_EXAMPLES=false
# ENABLE_GEMINI_FEWSHOT=true
# GOLDEN_EXAMPLES_STRATEGY=HIGH_QUALITY_GEMINI
# GOLDEN_EXAMPLES_COUNT=3
# GOLDEN_EXAMPLES_MIN_SCORE=85
# GEMINI_FEWSHOT_COUNT=2
# GEMINI_FEWSHOT_MIN_SCORE=85
# GEMINI_FEWSHOT_TOKEN_BUDGET_RATIO=0.15
# GEMINI_FEWSHOT_EXAMPLE_MAX_CHARS=700
# GEMINI_FEWSHOT_PROVIDER=gemini
# LLM_CONTEXT_WINDOW=4096
# FEWSHOT_TOKEN_BUDGET_RATIO=0.25
# ENABLE_REVIEW_GATED_FEWSHOT=false
# REVIEW_GATED_FEWSHOT_ONLY=false
# REVIEW_GATE_MIN_OVERALL=4.2
# REVIEW_DEFAULT_REVIEWER=owner


# ========================================
# 数据存储路径
# ========================================
RECORDS_PATH=./trilingual_records
RECORDS_TIMEZONE=Asia/Shanghai
DB_PATH=./data/trilingual_records.db


# ========================================
# TTS Service Endpoints (Phase 2)
# ========================================
# English -> Kokoro HTTP
TTS_EN_ENDPOINT=http://tts-en:8000/v1/audio/speech
TTS_EN_TYPE=kokoro
TTS_EN_MODEL=hexgrad/Kokoro-82M
TTS_EN_VOICE=af_bella
TTS_EN_SPEED=1.0

# Japanese -> VOICEVOX Engine
TTS_JA_ENDPOINT=http://tts-ja:50021
TTS_JA_TYPE=voicevox
# Optional speaker id (VOICEVOX)
# VOICEVOX_SPEAKER=2


# ========================================
# 渲染模式
# ========================================
HTML_RENDER_MODE=local


# ========================================
# 知识分析 — LLM 兜底（可选，均有默认值）
# ========================================
# cluster 语义分类任务：规则打底 + LLM 补未命中（services/knowledge/tasks/cluster.js）。
# 默认开启；关掉后未命中的卡只落各轴兜底桶（通用/其他、其他句式），不调用 Gemini。
# KNOWLEDGE_CLUSTER_LLM_ENABLED=true
# KNOWLEDGE_CLUSTER_LLM_TRANSPORT=proxy      # proxy | cli
# KNOWLEDGE_CLUSTER_MAX_LLM_CARDS=80         # 每个 job 送给模型的未命中卡上限
# KNOWLEDGE_CLUSTER_LLM_BATCH_SIZE=20        # 每次 LLM 调用的卡片批大小
# KNOWLEDGE_CLUSTER_LLM_TIMEOUT_MS=120000
# KNOWLEDGE_CLUSTER_MODEL=                    # 留空则回退 GEMINI_PROXY_MODEL / GEMINI_CLI_MODEL
# 下面四项留空即回退到对应的 GEMINI_PROXY_* 值：
# KNOWLEDGE_CLUSTER_PROXY_URL=
# KNOWLEDGE_CLUSTER_PROXY_AUTH_MODE=
# KNOWLEDGE_CLUSTER_PROXY_API_KEY=
# KNOWLEDGE_CLUSTER_PROXY_BEARER_TOKEN=
#
# synonym_boundary 同义边界任务（services/knowledge/tasks/synonymBoundary.js）。
# 默认关闭（纯本地启发式）；开启后对候选词对调用 Gemini produce richer payload。
# KNOWLEDGE_SYNONYM_LLM_ENABLED=false
# KNOWLEDGE_SYNONYM_LLM_TRANSPORT=proxy      # proxy | cli
# KNOWLEDGE_SYNONYM_LLM_TIMEOUT_MS=120000
# KNOWLEDGE_SYNONYM_LLM_RETRIES=1
# KNOWLEDGE_SYNONYM_LLM_RETRY_DELAY_MS=1200
# KNOWLEDGE_SYNONYM_MODEL=                    # 留空回退 GEMINI_PROXY_MODEL / GEMINI_CLI_MODEL
# KNOWLEDGE_SYNONYM_PROXY_URL=
# KNOWLEDGE_SYNONYM_PROXY_AUTH_MODE=
# KNOWLEDGE_SYNONYM_PROXY_API_KEY=
# KNOWLEDGE_SYNONYM_PROXY_BEARER_TOKEN=


# ========================================
# 配置说明
# ========================================
#
# 1. 推荐配置（本地LLM）:
#    - 完全离线运行，隐私安全，零成本
#    - 推荐模型：Qwen2.5-7B (中英日支持最佳)
#    - 速度：M4芯片 ~15 tok/s (Q4量化)
#
# 2. 如需重新启用 Gemini API:
#    - 访问: https://aistudio.google.com/app/apikey
#    - 获取API Key并填入 GEMINI_API_KEY
#    - 修改 server.js 默认 provider 为 'gemini'
#
# 3. Token 消耗参考（优化后）:
#    - 单次文本生成: ~1350 tokens (Prompt) + ~400 tokens (输出)
#    - 单次 OCR(Tesseract): 不消耗 LLM tokens
#    - 单次 OCR(Local 多模态): ~1000 tokens
#    - 本地LLM支持4K上下文模型
#

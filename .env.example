# ========================================
# DeepSeek 配置（/api/generate 当前生成路径）
# ========================================
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_TIMEOUT_MS=120000
DEEPSEEK_THINKING=disabled
# 成本估算可选覆盖项，单位为 USD / 1M tokens；留空时按 DEEPSEEK_MODEL 使用内置默认值。
# DEEPSEEK_INPUT_COST_PER_1M=
# DEEPSEEK_OUTPUT_COST_PER_1M=

# ========================================
# 本地/OpenAI-compatible LLM 配置（可选兜底/本地 OCR）
# ========================================
# 当前卡片生成固定走 DeepSeek；以下 LLM_* 仅供本地 OpenAI-compatible
# 端点、OCR local/auto 模式或开发调试使用。
LLM_BASE_URL=http://localhost:15800/v1
LLM_API_KEY=EMPTY
LLM_MODEL=qwen2_5_vl
LLM_OCR_MODEL=qwen2_5_vl

# LLM 参数配置
LLM_MAX_TOKENS=2048
LLM_OCR_MAX_TOKENS=512
LLM_TEMPERATURE=0.2
# LLM_OUTPUT_MODE=markdown

# 可选提示词模板覆盖；留空则使用仓库内默认模板。
# MARKDOWN_PROMPT_PATH=./prompts/phrase_3LANS_markdown.md
# GRAMMAR_MARKDOWN_PROMPT_PATH=./prompts/phrase_ja_grammar_markdown.md

# ========================================
# OCR 配置（推荐：Tesseract 独立容器）
# ========================================
# OCR_PROVIDER=tesseract   # tesseract | local | auto
# OCR_TESSERACT_ENDPOINT=http://ocr:8080/ocr
# OCR_LANGS=eng+jpn+chi_sim
# OCR_TIMEOUT_MS=20000

# ========================================
# 数据存储路径
# ========================================
RECORDS_PATH=./trilingual_records
RECORDS_TIMEZONE=Asia/Shanghai
DB_PATH=./data/trilingual_records.db


# ========================================
# TTS Service Endpoints (Phase 2)
# ========================================
# English -> Kokoro HTTP
TTS_EN_ENDPOINT=http://tts-en:8000/v1/audio/speech
TTS_EN_TYPE=kokoro
TTS_EN_MODEL=hexgrad/Kokoro-82M
TTS_EN_VOICE=af_bella
TTS_EN_SPEED=1.0

# Japanese -> VOICEVOX Engine (default / fallback)
TTS_JA_ENDPOINT=http://tts-ja:50021
TTS_JA_TYPE=voicevox
# Optional speaker id (VOICEVOX)
# VOICEVOX_SPEAKER=2

# Japanese primary -> Style-Bert-VITS2 (optional POC / future default)
# Set TTS_JA_TYPE=style_bert_vits2 after a local SBV2 API server is available.
# TTS_JA_SBV2_ENDPOINT=http://tts-ja-sbv2:5000
# TTS_JA_SBV2_MODEL_ID=0
# TTS_JA_SBV2_MODEL_NAME=
# TTS_JA_SBV2_SPEAKER_ID=0
# TTS_JA_SBV2_SPEAKER_NAME=
# TTS_JA_SBV2_STYLE=Neutral

# Optional SBV2 container POC parameters (`docker compose --profile sbv2 ...`)
# SBV2_HOST_PORT=15000
# SBV2_DEVICE=cpu
# SBV2_MODEL_REPO=litagin/style_bert_vits2_jvnv
# SBV2_MODEL_NAME=jvnv-F1-jp
# SBV2_MODEL_FILE=jvnv-F1-jp/jvnv-F1-jp_e160_s14000.safetensors
# SBV2_CONFIG_FILE=jvnv-F1-jp/config.json
# SBV2_STYLE_FILE=jvnv-F1-jp/style_vectors.npy
# SBV2_BERT_MODEL=ku-nlp/deberta-v2-large-japanese-char-wwm
# SBV2_ENABLE_OPENJTALK_WORKER=false


# ========================================
# 渲染模式
# ========================================
HTML_RENDER_MODE=local


# ========================================
# 知识分析 — LLM 兜底（可选，均有默认值）
# ========================================
# cluster 语义分类任务：规则打底 + LLM 补未命中（services/knowledge/tasks/cluster.js）。
# 默认开启；关掉后未命中的卡只落各轴兜底桶（通用/其他、其他句式），不调用 DeepSeek。
# KNOWLEDGE_CLUSTER_LLM_ENABLED=true
# KNOWLEDGE_CLUSTER_MAX_LLM_CARDS=80         # 每个 job 送给模型的未命中卡上限
# KNOWLEDGE_CLUSTER_LLM_BATCH_SIZE=20        # 每次 LLM 调用的卡片批大小
# KNOWLEDGE_CLUSTER_LLM_TIMEOUT_MS=120000
# KNOWLEDGE_CLUSTER_MODEL=                    # 留空则回退 DEEPSEEK_MODEL
#
# synonym_boundary 同义边界任务（services/knowledge/tasks/synonymBoundary.js）。
# 默认关闭（纯本地启发式）；开启后对候选词对调用 DeepSeek 生成更完整的边界说明。
# KNOWLEDGE_SYNONYM_LLM_ENABLED=false
# KNOWLEDGE_SYNONYM_LLM_TIMEOUT_MS=120000
# KNOWLEDGE_SYNONYM_MODEL=                    # 留空则回退 DEEPSEEK_MODEL


# ========================================
# 配置说明
# ========================================
#
# 1. 推荐配置（DeepSeek）:
#    - 设置 DEEPSEEK_API_KEY。
#    - 默认模型：deepseek-v4-flash。
#    - /api/generate、后台生成队列、知识 LLM 兜底均以 DeepSeek 为当前路径。
#
# 2. 可选本地/OpenAI-compatible LLM:
#    - LLM_* 不再是主卡片生成路径。
#    - OCR_PROVIDER=local 或 auto 时可通过 LLM_BASE_URL / LLM_OCR_MODEL 做本地图像识别。
#
# 3. Token 消耗参考（优化后）:
#    - 单次文本生成: ~1350 tokens (Prompt) + ~400 tokens (输出)
#    - 单次 OCR(Tesseract): 不消耗 LLM tokens
#    - 单次 OCR(Local 多模态): ~1000 tokens
#    - DeepSeek 成本按 DEEPSEEK_MODEL 与可选成本覆盖项估算
#

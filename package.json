{
  "name": "trilingual-records-viewer",
  "version": "1.0.0",
  "description": "Simple web viewer for local trilingual HTML records",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "gemini-proxy": "node scripts/gemini-host-proxy.js",
    "e2e:server": "bash ./scripts/startE2EServer.sh",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:smoke": "playwright test tests/e2e/smoke.spec.js",
    "test:e2e:pages": "playwright test tests/e2e/pages.spec.js",
    "test:e2e:gemini-sanitize": "playwright test tests/e2e/gemini-sanitize.spec.js",
    "test:e2e:real": "RUN_REAL_GEMINI_E2E=1 playwright test tests/e2e/real-gemini.spec.js",
    "test:e2e:real:nightly": "bash ./scripts/runRealNightlyE2E.sh",
    "training:backfill": "node scripts/backfillTrainingAssets.js",
    "cards:migrate-style": "node scripts/updateLegacyCardStyle.js --apply",
    "fewshot:rounds": "node scripts/run_fewshot_rounds.js",
    "fewshot:export-round": "node scripts/export_round_trend_dataset.js",
    "fewshot:render-round-charts": "node d3/render_round_trend_charts.mjs",
    "fewshot:report-round": "node scripts/generate_round_kpi_report.js"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "better-sqlite3": "^12.6.2",
    "d3": "^7.9.0",
    "dotenv": "^17.2.3",
    "express": "^4.19.2",
    "jsdom": "^27.4.0",
    "kuroshiro": "^1.2.0",
    "kuroshiro-analyzer-kuromoji": "^1.1.0",
    "marked": "^9.1.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2"
  }
}

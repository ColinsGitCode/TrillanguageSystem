{
  "name": "trilingual-records-viewer",
  "version": "1.0.0",
  "description": "Simple web viewer for local trilingual HTML records",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "gemini-proxy": "node scripts/infra/gemini-host-proxy.js",
    "test": "node --test tests/unit/*.test.js",
    "test:unit": "node --test tests/unit/*.test.js",
    "test:integration": "node --test tests/integration/*.test.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "smoke": "bash ./scripts/tests/smoke.sh",
    "e2e:server": "bash ./scripts/tests/startE2EServer.sh",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:smoke": "playwright test tests/e2e/smoke.spec.js",
    "test:e2e:pages": "playwright test tests/e2e/pages.spec.js",
    "test:e2e:gemini-sanitize": "playwright test tests/e2e/gemini-sanitize.spec.js",
    "test:e2e:real": "RUN_REAL_GEMINI_E2E=1 playwright test tests/e2e/real-gemini.spec.js",
    "test:e2e:real:nightly": "bash ./scripts/tests/runRealNightlyE2E.sh",
    "training:backfill": "node scripts/migrations/backfillTrainingAssets.js",
    "cards:migrate-style": "node scripts/migrations/updateLegacyCardStyle.js --apply",
    "fewshot:rounds": "node scripts/fewshot/run_fewshot_rounds.js",
    "fewshot:export-round": "node scripts/fewshot/export_round_trend_dataset.js",
    "fewshot:render-round-charts": "node d3/render_round_trend_charts.mjs",
    "fewshot:report-round": "node scripts/fewshot/generate_round_kpi_report.js"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "better-sqlite3": "^12.6.2",
    "d3": "^7.9.0",
    "dotenv": "^17.2.3",
    "express": "^4.19.2",
    "jsdom": "^27.4.0",
    "kuroshiro": "^1.2.0",
    "kuroshiro-analyzer-kuromoji": "^1.1.0",
    "marked": "^9.1.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "eslint": "^9.39.4",
    "globals": "^15.15.0"
  }
}
